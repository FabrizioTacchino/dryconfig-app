# Esempio variabili d'ambiente DryConfig (Vite legge solo prefisso VITE_).
# Copia questo file in `.env` (gitignored) e compila i valori per il tuo
# ambiente locale. Su Vercel imposta le stesse variabili da
# Settings → Environment Variables.

# Supabase project URL (es. https://aifeyamngllcezkoxzxu.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon/publishable key (JWT). Sicura nel bundle frontend
# perché tutti gli accessi DB sono protetti da RLS server-side.
VITE_SUPABASE_ANON_KEY=

# === Sentry (monitoraggio errori frontend) ===
# DSN del progetto Sentry (es. https://<key>@o000.ingest.sentry.io/0000).
# Se vuoto, Sentry è disabilitato (no-op) — utile in dev locale.
VITE_SENTRY_DSN=

# Identificativo release (opzionale). Su Vercel viene popolato automaticamente
# col commit SHA via VERCEL_GIT_COMMIT_SHA. In locale puoi lasciarlo vuoto.
VITE_SENTRY_RELEASE=

# === Sentry source maps upload (solo build prod) ===
# Token con scope project:releases. Generalo su sentry.io → Settings → Account
# → Auth Tokens. Tenerlo SEGRETO (non committare). Su Vercel impostare come
# Environment Variable senza prefisso VITE_ (= server-side only).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
